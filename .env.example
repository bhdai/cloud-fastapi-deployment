# ==============================================================================
# Environment Variables Template
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (with docker-compose --profile local):
DATABASE_URL=postgresql://postgres:postgres@db:5432/fastapi_dev
# Production (RDS) — replace with your RDS endpoint:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-rds-endpoint:5432/fastapi_prod

# ── AWS Credentials ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-1

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=fastapi-app-files-your-id

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Product Catalog API
DEBUG=false
ENVIRONMENT=development
